# Entra ID App Registration
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Azure Storage (Table Storage für User-Credentials)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Verschlüsselung der Jira-Tokens at rest
# Generieren: openssl rand -hex 32
ENCRYPTION_KEY=<64-stelliger-hex-string>

# HMAC-Signierung der Setup-Links
# Generieren: openssl rand -base64 32
SETUP_SECRET=<beliebiger-langer-zufaelliger-string>

# Öffentliche URL des Servers (ohne abschliessenden Slash)
APP_URL=https://mcp-jira.xyz.azurecontainerapps.io

PORT=3003
