# Jira Cloud URL (z.B. https://deine-firma.atlassian.net)
JIRA_URL=https://your-domain.atlassian.net

# Jira Account E-Mail
JIRA_EMAIL=deine@email.com

# Jira API Token (generieren unter: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_TOKEN=your-api-token-here

# API-Key für den MCP Server (beliebiger sicherer String)
API_KEY=your-api-key-here
